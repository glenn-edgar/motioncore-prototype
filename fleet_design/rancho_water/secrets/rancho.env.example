# rancho_water robot credentials.
#
# Copy to rancho.env (same directory) and fill in the real values. rancho.env
# is gitignored — never commit it. run.sh sources it before launch.
#
# (Alternative: leave rancho.env absent and put the same vars in
# ../farm_soil/secrets/ttn.env — run.sh falls back to that file. Useful
# while there's only one operator account.)
#
# RANCHO_WATER_ACCOUNT  — the username / email used to log in to
#                         myaccount.ranchowater.com.
# RANCHO_WATER_PASSWORD — the corresponding password.
# RANCHO_WATER_ACCOUNT_NUMBER — optional; the meter/billing account
#                         number that appears in the API responses
#                         (e.g. "3047791"). Default in class_spec.lua.
RANCHO_WATER_ACCOUNT=your-portal-username
RANCHO_WATER_PASSWORD=your-portal-password
# RANCHO_WATER_ACCOUNT_NUMBER=3047791
