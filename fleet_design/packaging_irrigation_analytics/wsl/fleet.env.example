# packaging_irrigation_analytics/wsl/fleet.env.example
# Copy to fleet.env (gitignored) and edit. Every entry is optional; start.sh
# sets sensible defaults.

# --- Image ---
# IMAGE_TAG=nanodatacenter/irrigation-analytics:wsl
# CONTAINER_NAME=irrigation-analytics

# --- Networking ---
# NETWORK_MODE=bridge          # bridge (default) | host
# GATEWAY_PORT=28080           # host port for the dashboard (HTTP)
# ZENOH_HOST_PORT=27447        # host port for zenohd (-> internal 7447)
# GATEWAY_HOST=127.0.0.1       # auto-forced to 0.0.0.0 in bridge mode
# ZENOH_LOCATOR=tcp/127.0.0.1:7447  # in-container locator (don't change)

# --- Robot instance ---
# IRRIGATION_ANALYTICS_INSTANCE=lacima

# --- Controller SSH alias (used inside the container by controller_client) ---
# IRRIGATION_CONTROLLER_HOST=pi@irrigation
# Container must have an SSH key + ~/.ssh/config that resolves "irrigation" —
# bind-mount these via DATA_DIR (.ssh under /var/fleet) or via SECRETS_DIR.
# See wsl/README.md for the bench setup recipe.

# --- Docker restart policy ---
# RESTART_POLICY=unless-stopped

# --- Bind-mount overrides (default: <this-dir>/var and <this-dir>/secrets) ---
# DATA_DIR=/var/lib/irrigation-analytics
# SECRETS_DIR=/etc/irrigation-analytics/secrets
