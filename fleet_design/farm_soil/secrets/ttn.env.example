# TTN credentials for the farm_soil robot.
#
# Copy to ttn.env (same directory) and fill in the real value. ttn.env is
# gitignored — never commit it. run.sh sources this file into the process
# environment before launching the robot.
#
# The bearer token is a TTN application API key (format NNSXS.<id>.<secret>).
# If a token was ever committed in plaintext anywhere, rotate it in TTN — a
# git history rewrite does not un-expose it.
TTN_BEARER_TOKEN=NNSXS.xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
