# packaging/wsl/fleet.env.example — copy to fleet.env (gitignored) and edit.
#
# Every entry is OPTIONAL; the start.sh wrapper sets defaults. Override the
# few that differ between WSL bench and Pi production.

# --- Image ---
# IMAGE_TAG=fleet-mcfarland:wsl
# CONTAINER_NAME=fleet

# --- Networking ---
# NETWORK_MODE:
#   bridge — port-published. REQUIRED on Docker Desktop (Mac/Windows/WSL)
#            because --network=host does not actually share the host
#            namespace on those platforms. Default.
#   host   — real --network=host. Pi (linux docker) wants this.
# NETWORK_MODE=bridge
#
# In bridge mode, GATEWAY_HOST is forced to 0.0.0.0 inside the container.
# In host mode, GATEWAY_HOST defaults to 127.0.0.1 — Pi production sets it
# to 0.0.0.0 so the dashboard is reachable from any LAN client.
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=8080
# ZENOH_LOCATOR=tcp/127.0.0.1:7447

# --- Robot instances ---
# FARM_SOIL_INSTANCE=lacima01
# RANCHO_WATER_INSTANCE=main

# --- Docker restart policy ---
# RESTART_POLICY=unless-stopped

# --- Bind-mount overrides (default: <this-dir>/var and <this-dir>/secrets) ---
# DATA_DIR=/var/lib/fleet
# SECRETS_DIR=/etc/fleet/secrets
